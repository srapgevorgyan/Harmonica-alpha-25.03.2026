<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:background="@color/harmonica_bg"
    android:padding="24dp">

    <ImageView
        android:id="@+id/logo_box"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_sidebar_active"
        android:padding="12dp"
        android:src="@drawable/ic_heart"
        app:tint="@color/white"
        android:layout_marginTop="28dp"
        />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@id/logo_box"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harmonica"
            android:textColor="#1A1A1A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:text="WELLNESS\nASSISTANT"
            android:textColor="@color/harmonica_text_sub"
            android:textSize="10sp" />
    </LinearLayout>

</RelativeLayout>