<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Harmonica" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        
        <!-- Fix for the purple status bar -->
        <item name="android:statusBarColor">@color/harmonica_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        
        <!-- Overriding Material3 defaults to prevent purple -->
        <item name="colorPrimary">@color/harmonica_primary</item>
        <item name="colorSecondary">@color/harmonica_olive</item>
        <item name="android:windowBackground">@color/harmonica_bg</item>
    </style>
    
    <style name="ShapeAppearance.Harmonica.Pill" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <style name="Theme.Harmonica" parent="Base.Theme.Harmonica" />
    
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/harmonica_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.Harmonica</item>
    </style>
</resources>